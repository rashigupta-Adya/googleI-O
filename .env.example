# ============================================================
#  GIO Connect — environment variables
#  In Vercel: Project → Settings → Environment Variables.
# ============================================================

# --- Google Sheets (lead capture) — REQUIRED ---
GOOGLE_SHEETS_SPREADSHEET_ID=
# Either the full service-account JSON on one line:
GOOGLE_SERVICE_ACCOUNT_JSON=
# ...or these two instead:
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_GIO_TAB=gio
GOOGLE_SHEETS_GIO_CLICKS_TAB=gio_clicks

# --- Resend (E1 welcome email) — REQUIRED to send email ---
RESEND_API_KEY=
RESEND_FROM=Adya <hello@adya.ai>
RESEND_REPLY_TO=hello@adya.ai

# --- Product signup destinations (desktop redirect) ---
# Pre-set in code to the live product URLs, so you can leave these blank.
# Set them only to override the defaults:
#   PRODUCT_SIGNUP_URL_VANIJ=https://vanij.adya.ai/orchestrator
#   PRODUCT_SIGNUP_URL_GTM=https://gtm.adya.ai/orchestrator
#   PRODUCT_SIGNUP_URL_RAS=https://esa.adya.ai/

# --- Optional ---
# The email link + redirects auto-derive the domain from the request, so SITE_ORIGIN
# is optional. Set it only to force a fixed domain in emails (e.g. after moving to adya.ai).
# SITE_ORIGIN=https://adya.ai
# Leave the rate limiter OFF at the booth (venue wifi is one shared IP). Honeypot is primary.
# GIO_RATE_LIMIT=off
